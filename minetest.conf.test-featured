server_announce = false

## Network

port = 30005


## Game

default_game = lord
motd = На сервере включены все фичи, тестирование обычно требует комлексного подхода и рельной игры
max_users = 6
enable_damage = true
creative_mode = false
fixed_map_seed = badger
default_password = 456852
disallow_empty_password = true
default_privs = shout, interact, spawn, info, news, home
player_transfer_distance = 1000
enable_pvp = true

static_spawnpoint = 330, 20, 160

enable_rollback_recording = true
ask_reconnect_on_crash = true
time_speed = 24

## Security
# А НА ПРОДЕ `false` !!!
